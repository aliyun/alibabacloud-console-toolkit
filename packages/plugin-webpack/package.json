{
  "name": "@alicloud/console-toolkit-plugin-webpack",
  "version": "2.0.0-alpha.3",
  "description": "console toolkit plugin for webpack engine",
  "author": "boelroy <boelroy@live.com>",
  "license": "MIT",
  "main": "lib/index.js",
  "scripts": {
    "ci": "npm run lint && npm run compile && npm run cov",
    "lint": "tslint --project .",
    "compile": "rm -rf ./lib && tsc -d true -p ./",
    "watch": "tsc -watch -d true -p ./",
    "test": "jest",
    "cov": "jest  --coverage",
    "postinstall": "node scripts/link.js",
    "prepare": "npm run compile"
  },
  "devDependencies": {
    "@types/chai": "^4.1.7",
    "@types/debug": "^4.1.5",
    "@types/jest": "^24.0.18",
    "@types/lodash": "^4.14.116",
    "@types/node": "^12.7.5",
    "@types/package-json": "^5.0.0",
    "@types/rimraf": "^2.0.2",
    "@types/webpack-chain": "^5.0.0",
    "@types/webpack-dev-server": "^4.0.0",
    "@types/webpack-merge": "^5.0.0",
    "chai": "^4.2.0",
    "jest": "^24.2.0-alpha.0",
    "nyc": "^14.1.1",
    "rimraf": "^3.0.0",
    "ts-jest": "^24.0.0",
    "ts-node": "^8.4.1",
    "typescript": "^4.0.0"
  },
  "dependencies": {
    "@alicloud/console-toolkit-core": "^1.2.30",
    "@alicloud/console-toolkit-shared-utils": "^1.2.30",
    "@gem-mine/webpack-chain": "^7.0.0",
    "@types/express": "^4.17.13",
    "@types/webpack": "^5.0.0",
    "assert": "^2.0.0",
    "browserify-zlib": "^0.2.0",
    "buffer": "^6.0.3",
    "chalk": "^2.4.2",
    "console-browserify": "^1.2.0",
    "constants-browserify": "^1.0.0",
    "crypto-browserify": "^3.12.0",
    "debug": "^4.0.1",
    "domain-browser": "^4.22.0",
    "express": "^4.18.1",
    "fs-extra": "^8.1.0",
    "https-browserify": "^1.0.0",
    "lodash": "^4.17.11",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "querystring-es3": "^0.2.1",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "string.prototype.padend": "^3.0.0",
    "timers-browserify": "^2.0.12",
    "tty-browserify": "0.0.1",
    "vm-browserify": "^1.1.2",
    "webpack": "^5.0.0",
    "webpack-dev-server": "^4.0.0",
    "webpack-merge": "^5.0.0"
  },
  "ci": {
    "type": "aoneci",
    "version": "8",
    "docker": true,
    "tags": "",
    "fntest": false,
    "command": "ci",
    "cpp": false,
    "autoBadges": true,
    "image": ""
  },
  "nyc": {
    "include": [
      "src/**/*.ts"
    ],
    "extension": [
      ".ts"
    ],
    "require": [
      "ts-node/register"
    ],
    "reporter": [
      "text-summary",
      "json",
      "json-summary",
      "lcov"
    ],
    "temp-dir": "./node_modules/.nyc_output",
    "sourceMap": true,
    "instrument": true
  },
  "gitHead": "2f3e37686a805e56fb3a7a8a283abcf484fe8b7a"
}
